{
  "name": "planify",
  "type": "application",
  "buildType": "dockerfile",
  "dockerfile": "Dockerfile",
  "port": 3001,
  "env": {
    "NODE_ENV": "production",
    "PORT": "3001"
  },
  "volumes": [
    {
      "hostPath": "/var/lib/dokploy/planify/data",
      "containerPath": "/app/data"
    }
  ],
  "healthCheck": {
    "path": "/api/health",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  }
}
